```gitignore
# Compiled and binary files
*.pyc
__pycache__/

# Dependencies
.venv/
venv/
node_modules/

# Build artifacts
dist/
build/
target/

# Logs and temporary files
*.log
*.tmp
*.swp

# Environment files
.env
.env.local
*.env.*

# Editors and IDE
.vscode/
.idea/
*.swp
*.swo

# Coverage reports
coverage/
htmlcov/
.coverage

# MyPy cache
.mypy_cache/

# Pytest cache
.pytest_cache/

# OS generated files
.DS_Store
Thumbs.db
```