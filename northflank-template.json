{
  "apiVersion": "v1",
  "kind": "Template",
  "metadata": {
    "name": "openclaw-automated-deployment",
    "description": "Deploy Open Claw headless engine to Hugging Face Space Pro via Northflank IaC pipeline"
  },
  "spec": {
    "arguments": [
      {
        "name": "OPENCLAW_TELEGRAM_BOT_TOKEN",
        "type": "secret",
        "description": "Telegram Bot Token from BotFather"
      },
      {
        "name": "OPENCLAW_HUGGINGFACE_API_KEY",
        "type": "secret",
        "description": "Hugging Face API Key for model access"
      },
      {
        "name": "GIT_REPO_URL",
        "type": "string",
        "description": "Git repository URL containing the Dockerfile"
      }
    ],
    "workflow": {
      "type": "sequential",
      "nodes": [
        {
          "id": "target-project",
          "kind": "Project",
          "spec": {
            "name": "openclaw-headless-runtime",
            "region": "europe-west"
          }
        },
        {
          "id": "secure-runtime-secrets",
          "kind": "SecretGroup",
          "spec": {
            "name": "openclaw-multi-provider-credentials",
            "projectContext": "${target-project.id}",
            "secrets": [
              {
                "name": "OPENCLAW_TELEGRAM_BOT_TOKEN",
                "value": "${arguments.OPENCLAW_TELEGRAM_BOT_TOKEN}"
              },
              {
                "name": "OPENCLAW_HUGGINGFACE_API_KEY",
                "value": "${arguments.OPENCLAW_HUGGINGFACE_API_KEY}"
              },
              {
                "name": "OPENCLAW_HF_TOKEN",
                "value": "${arguments.OPENCLAW_HUGGINGFACE_API_KEY}"
              }
            ]
          }
        },
        {
          "id": "stateful-storage-volume",
          "kind": "Volume",
          "spec": {
            "name": "openclaw-state",
            "projectContext": "${target-project.id}",
            "capacity": "4GB",
            "accessMode": "shared-read-write-once"
          }
        },
        {
          "id": "headless-daemon-worker",
          "kind": "Service",
          "spec": {
            "name": "openclaw-gateway",
            "projectContext": "${target-project.id}",
            "type": "worker",
            "billingPlan": "micro",
            "source": {
              "type": "vcs",
              "repository": "${arguments.GIT_REPO_URL}",
              "branch": "main"
            },
            "build": {
              "method": "dockerfile",
              "path": "./Dockerfile"
            },
            "instances": 1,
            "volumes": [
              {
                "volumeId": "${stateful-storage-volume.id}",
                "mountPath": "/data"
              }
            ],
            "envFrom": [
              {
                "secretGroupRef": "${secure-runtime-secrets.id}"
              }
            ]
          }
        }
      ]
    }
  }
}
