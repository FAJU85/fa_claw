{
  "apiVersion": "v1.2",
  "name": "openclaw-automated-deployment",
  "description": "Deploy the Open Claw headless Telegram + Hugging Face daemon to Northflank via an Infrastructure-as-Code pipeline.",
  "arguments": {
    "OPENCLAW_TELEGRAM_BOT_TOKEN": "",
    "OPENCLAW_HUGGINGFACE_API_KEY": "",
    "GIT_REPO_URL": "https://github.com/FAJU85/fa_claw",
    "GIT_BRANCH": "main",
    "PROJECT_REGION": "europe-west",
    "DEPLOYMENT_PLAN": "nf-compute-20",
    "BUILD_PLAN": "nf-compute-400-16"
  },
  "options": {
    "autorun": false,
    "concurrencyPolicy": "allow"
  },
  "spec": {
    "kind": "Workflow",
    "spec": {
      "type": "sequential",
      "steps": [
        {
          "kind": "Project",
          "ref": "project",
          "spec": {
            "name": "openclaw-headless-runtime",
            "region": "${args.PROJECT_REGION}",
            "networking": {
              "allowedIngressProjects": []
            }
          }
        },
        {
          "kind": "Workflow",
          "spec": {
            "type": "sequential",
            "context": {
              "projectId": "${refs.project.id}"
            },
            "steps": [
              {
                "kind": "SecretGroup",
                "ref": "secrets",
                "spec": {
                  "name": "openclaw-credentials",
                  "secretType": "environment",
                  "priority": 10,
                  "restrictions": {
                    "restricted": true,
                    "nfObjects": [],
                    "tags": ["openclaw"],
                    "tagMatchCondition": "or"
                  },
                  "secrets": {
                    "variables": {
                      "OPENCLAW_TELEGRAM_BOT_TOKEN": "${args.OPENCLAW_TELEGRAM_BOT_TOKEN}",
                      "OPENCLAW_HUGGINGFACE_API_KEY": "${args.OPENCLAW_HUGGINGFACE_API_KEY}",
                      "OPENCLAW_HF_TOKEN": "${args.OPENCLAW_HUGGINGFACE_API_KEY}"
                    }
                  }
                }
              },
              {
                "kind": "CombinedService",
                "ref": "service",
                "spec": {
                  "name": "openclaw-gateway",
                  "tags": ["openclaw"],
                  "billing": {
                    "deploymentPlan": "${args.DEPLOYMENT_PLAN}",
                    "buildPlan": "${args.BUILD_PLAN}"
                  },
                  "deployment": {
                    "instances": 1,
                    "docker": {
                      "configType": "default"
                    },
                    "storage": {
                      "ephemeralStorage": {
                        "storageSize": 1024
                      },
                      "shmSize": 64
                    }
                  },
                  "vcsData": {
                    "projectType": "github",
                    "projectUrl": "${args.GIT_REPO_URL}",
                    "projectBranch": "${args.GIT_BRANCH}"
                  },
                  "buildSettings": {
                    "dockerfile": {
                      "buildEngine": "kaniko",
                      "useCache": false,
                      "dockerFilePath": "/Dockerfile",
                      "dockerWorkDir": "/"
                    }
                  },
                  "runtimeEnvironment": {},
                  "ports": [],
                  "disabledCI": false
                }
              },
              {
                "kind": "Volume",
                "ref": "volume",
                "spec": {
                  "name": "openclaw-state",
                  "mounts": [
                    {
                      "containerMountPath": "/data"
                    }
                  ],
                  "spec": {
                    "storageClassName": "ssd",
                    "storageSize": 4096
                  },
                  "attachedObjects": [
                    {
                      "id": "${refs.service.id}",
                      "type": "service"
                    }
                  ]
                }
              }
            ]
          }
        }
      ]
    }
  }
}
